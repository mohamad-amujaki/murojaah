{
  "name": "@murojaah/web",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:seed:local": "wrangler d1 execute DB --local --file=../../packages/db/seeds/local.sql"
  },
  "dependencies": {
    "@murojaah/db": "workspace:*",
    "@murojaah/shared": "workspace:*",
    "@tanstack/react-router": "latest",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.16.1",
    "@cloudflare/workers-types": "^5.20260710.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "wrangler": "^4.50.0"
  }
}
